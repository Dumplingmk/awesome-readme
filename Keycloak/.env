# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change_me_strong_password

# ─── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_admin_password
KC_HOSTNAME=localhost           # 換成你的 domain，例如 auth.example.com
KC_PORT=8080

# ─── Backup ───────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7        # 保留天數
BACKUP_SCHEDULE=0 2 * * *      # 每天凌晨 2 點備份 (cron 格式)